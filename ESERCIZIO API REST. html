const express = require("express");
const router = express.Router();
let { items } = require("../data/db"); 

/**
 
 */
router.get("/", (req, res) => {
    res.json(items);
});

/**
 
 */
router.get("/:id", (req, res) => {
    const id = parseInt(req.params.id);
    const item = items.find(i => i.id === id);
    if (!item) return res.status(404).json({ message: "Elemento non trovato" });
    res.json(item);
});

/**
 
 */
router.post("/", (req, res) => {
    const newItem = {
        id: items.length > 0 ? items[items.length - 1].id + 1 : 1,
        name: req.body.name || "Nuovo Item"
    };
    items.push(newItem);
    res.status(201).json(newItem);
});

/**
 
 */
router.put("/:id", (req, res) => {
    const id = parseInt(req.params.id);
    const itemIndex = items.findIndex(i => i.id === id);
    
    if (itemIndex === -1) return res.status(404).json({ message: "Elemento non trovato" });
    
    items[itemIndex] = { ...items[itemIndex], ...req.body };
    res.json(items[itemIndex]);
});

/**
 
 */
router.delete("/:id", (req, res) => {
    const id = parseInt(req.params.id);
    const initialLength = items.length;
    items = items.filter(i => i.id !== id);
    
    if (items.length === initialLength) {
        return res.status(404).json({ message: "Elemento non trovato" });
    }
    
    res.json({ message: "Elemento eliminato con successo" });
});

module.exports = router;
